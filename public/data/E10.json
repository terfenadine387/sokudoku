[{"start": 0.0, "end": 2.78, "text": "He is a doctor and also a painter.", "words": [{"w": "He", "s": 0.0, "e": 0.6}, {"w": "is", "s": 0.6, "e": 0.76}, {"w": "a", "s": 0.76, "e": 0.9}, {"w": "doctor", "s": 0.9, "e": 1.22}, {"w": "and", "s": 1.22, "e": 1.82}, {"w": "also", "s": 1.82, "e": 2.26}, {"w": "a", "s": 2.26, "e": 2.5}, {"w": "painter.", "s": 2.5, "e": 2.78}]}, {"start": 5.64, "end": 9.16, "text": "We must all work together to protect human rights.", "words": [{"w": "We", "s": 5.64, "e": 6.36}, {"w": "must", "s": 6.36, "e": 6.58}, {"w": "all", "s": 6.58, "e": 6.84}, {"w": "work", "s": 6.84, "e": 7.06}, {"w": "together", "s": 7.06, "e": 7.48}, {"w": "to", "s": 7.48, "e": 7.8}, {"w": "protect", "s": 7.8, "e": 8.3}, {"w": "human", "s": 8.3, "e": 8.72}, {"w": "rights.", "s": 8.72, "e": 9.16}]}, {"start": 12.04, "end": 14.54, "text": "I'm really sorry that I broke your pen.", "words": [{"w": "I'm", "s": 12.04, "e": 12.76}, {"w": "really", "s": 12.76, "e": 12.94}, {"w": "sorry", "s": 12.94, "e": 13.36}, {"w": "that", "s": 13.36, "e": 13.58}, {"w": "I", "s": 13.58, "e": 13.72}, {"w": "broke", "s": 13.72, "e": 13.92}, {"w": "your", "s": 13.92, "e": 14.18}, {"w": "pen.", "s": 14.18, "e": 14.54}]}, {"start": 17.34, "end": 19.68, "text": "She fixed his shelf to the wall.", "words": [{"w": "She", "s": 17.34, "e": 18.06}, {"w": "fixed", "s": 18.06, "e": 18.36}, {"w": "his", "s": 18.36, "e": 18.6}, {"w": "shelf", "s": 18.6, "e": 18.96}, {"w": "to", "s": 18.96, "e": 19.22}, {"w": "the", "s": 19.22, "e": 19.36}, {"w": "wall.", "s": 19.36, "e": 19.68}]}, {"start": 22.6, "end": 25.44, "text": "My smartphone is now being repaired.", "words": [{"w": "My", "s": 22.6, "e": 23.32}, {"w": "smartphone", "s": 23.32, "e": 23.84}, {"w": "is", "s": 23.84, "e": 24.26}, {"w": "now", "s": 24.26, "e": 24.54}, {"w": "being", "s": 24.54, "e": 24.9}, {"w": "repaired.", "s": 24.9, "e": 25.44}]}, {"start": 28.22, "end": 30.88, "text": "The storm damaged the crops.", "words": [{"w": "The", "s": 28