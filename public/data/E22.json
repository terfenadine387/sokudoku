[{"start": 0.0, "end": 3.18, "text": "Are you sure that your idea is the best one?", "words": [{"w": "Are", "s": 0.0, "e": 0.6}, {"w": "you", "s": 0.6, "e": 0.82}, {"w": "sure", "s": 0.82, "e": 1.16}, {"w": "that", "s": 1.16, "e": 1.44}, {"w": "your", "s": 1.44, "e": 1.68}, {"w": "idea", "s": 1.68, "e": 2.2}, {"w": "is", "s": 2.2, "e": 2.44}, {"w": "the", "s": 2.44, "e": 2.6}, {"w": "best", "s": 2.6, "e": 2.9}, {"w": "one?", "s": 2.9, "e": 3.18}]}, {"start": 6.2, "end": 9.64, "text": "Parents often tell their children stories at bedtime.", "words": [{"w": "Parents", "s": 6.2, "e": 6.84}, {"w": "often", "s": 6.84, "e": 7.3}, {"w": "tell", "s": 7.3, "e": 7.62}, {"w": "their", "s": 7.62, "e": 7.9}, {"w": "children", "s": 7.9, "e": 8.32}, {"w": "stories", "s": 8.32, "e": 8.9}, {"w": "at", "s": 8.9, "e": 9.22}, {"w": "bedtime.", "s": 9.22, "e": 9.64}]}, {"start": 12.72, "end": 15.28, "text": "Do you know the legend in this book?", "words": [{"w": "Do", "s": 12.72, "e": 13.36}, {"w": "you", "s": 13.36, "e": 13.58}, {"w": "know", "s": 13.58, "e": 13.82}, {"w": "the", "s": 13.82, "e": 14.04}, {"w": "legend", "s": 14.04, "e": 14.48}, {"w": "in", "s": 14.48, "e": 14.78}, {"w": "this", "s": 14.78, "e": 15.02}, {"w": "book?", "s": 15.02, "e": 15.28}]}, {"start": 18.3, "end": 21.52, "text": "The two countries have been at war for decades.", "words": [{"w": "The", "s": 18.3, "e": 18.94}, {"w": "two", "s": 18.94, "e": 19.18}, {"w": "countries", "s": 19.18, "e": 19.66}, {"w": "have", "s": 19.66, "e": 20.06}, {"w": "been", "s": 20.06, "e": 20.32}, {"w": "at", "s": 20.32, "e": 20.48}, {"w": "war", "s": 20.48, "e": 20.74}, {"w": "for", "s": 20.74, "e": 21.1}, {"w": "decades.", "s": 21.1, "e": 21.52}]}, {"start": 24.62, "end": 26.3, "text": "I had a light breakfast.", "words": [{"w": "I", "s": 24.62, "e": 25.26}, {"w": "had", "s": 25.26, "e": 25.48}, {"w": "a", "s": 25.48, "e": 25.64}, {"w": "light", "s": 25.64, "e": 25.82}, {"w": "breakfast.", "s": 25.82, "e": 26.3}]}, {"start": 29.36, "end": 32.16, "text": "He felt lighter at heart when he saw her.", "words": [{"w": "He", "s": 29.36, "e": 30.02}, {"w": "felt", "s": 30.02, "e": 30.3}, {"w": "lighter", "s": 30.3, "e": 30.66}, {"w": "at", "s": 30.66, "e": 30.92}, {"w": "heart", "s": 30.92, "e": 31.24}, {"w": "when", "s": 31.24, "e": 31.46}, {"w": "he", "s": 31.46, "e": 31.64}, {"w": "saw", "s": 31.64, "e": 31.9}, {"w": "her.", "s": 31.9, "e": 32.16}]}, {"start": 35.0, "end": 37.04, "text": "The sun is shining brightly.", "words": [{"w": "The", "s": 35.0, "e": 35.66}, {"w": "sun", "s": 35.66, "e": 35.96}, {"w": "is", "s": 35.96, "e": 36.14}, {"w": "shining", "s": 36.14, "e": 36.5}, {"w": "brightly.", "s": 36.5, "e": 37.04}]}, {"start": 40.06, "end": 42.52, "text": "What time does it get dark in winter?", "words": [{"w": "What", "s": 40.06, "e": 40.72}, {"w": "time", "s": 40.72, "e": 41.1}, {"w": "does", "s": 41.1, "e": 41.32}, {"w": "it", "s": 41.32, "e": 41.44}, {"w": "get", "s": 41.44, "e": 41.62}, {"w": "dark", "s": 41.62, "e": 42.0}, {"w": "in", "s": 42.0, "e": 42.24}, {"w": "winter?", "s": 42.24, "e": 42.52}]}, {"start": 45.6, "end": 48.76, "text": "My father was in the army for 30 years.", "words": [{"w": "My", "s": 45.6, "e": 46.26}, {"w": "father", "s": 46.26, "e": 46.62}, {"w": "was", "s": 46.62, "e": 47.0}, {"w": "in", "s": 47.0, "e": 47.18}, {"w": "the", "s": 47.18, "e": 47.36}, {"w": "army", "s": 47.36, "e": 47.64}, {"w": "for", "s": 47.64, "e": 48.0}, {"w": "30", "s": 48.0, "e": 48.34}, {"w": "years.", "s": 48.34, "e": 48.76}]}, {"start": 51.82, "end": 55.88, "text": "I believe we should reduce the money we spend on the military.", "words": [{"w": "I", "s": 51.82, "e": 52.48}, {"w": "believe", "s": 52.48, "e": 52.82}, {"w": "we", "s": 52.82, "e": 53.14}, {"w": "should", "s": 53.14, "e": 53.38}, {"w": "reduce", "s": 53.38, "e": 53.78}, {"w": "the", "s": 53.78, "e": 54.08}, {"w": "money", "s": 54.08, "e": 54.32}, {"w": "we", "s": 54.32, "e": 54.56}, {"w": "spend", "s": 54.56, "e": 54.82}, {"w": "on", "s": 54.82, "e": 55.18}, {"w": "the", "s": 55.18, "e": 55.32}, {"w": "military.", "s": 55.32, "e": 55.88}]}, {"start": 58.84, "end": 61.88, "text": "The world should work hard to eliminate nuclear weapons.", "words": [{"w": "The", "s": 58.84, "e": 59.48}, {"w": "world", "s": 59.48, "e": 59.8}, {"w": "should", "s": 59.8, "e": 60.08}, {"w": "work", "s": 60.08, "e": 60.32}, {"w": "hard", "s": 60.32, "e": 60.7}, {"w": "to", "s": 60.7, "e": 60.94}, {"w": "eliminate", "s": 60.94, "e": 61.42}, {"w": "nuclear", "s": 61.42, "e": 61.86}, {"w": "weapons.", "s": 61.86, "e": 62.18}]}, {"start": 65.66, "end": 67.92, "text": "Black clouds are a sign of rain.", "words": [{"w": "Black", "s": 65.66, "e": 66.3}, {"w": "clouds", "s": 66.3, "e": 66.82}, {"w": "are", "s": 66.82, "e": 67.04}, {"w": "a", "s": 67.04, "e": 67.24}, {"w": "sign", "s": 67.24, "e": 67.42}, {"w": "of", "s": 67.42, "e": 67.62}, {"w": "rain.", "s": 67.62, "e": 67.92}]}, {"start": 70.98, "end": 73.34, "text": "Mark the words you don't understand.", "words": [{"w": "Mark", "s": 70.98, "e": 71.62}, {"w": "the", "s": 71.62, "e": 71.9}, {"w": "words", "s": 71.9, "e": 72.24}, {"w": "you", "s": 72.24, "e": 72.44}, {"w": "don't", "s": 72.44, "e": 72.74}, {"w": "understand.", "s": 72.74, "e": 73.34}]}, {"start": 76.32, "end": 78.4, "text": "It was like I was in heaven.", "words": [{"w": "It", "s": 76.32, "e": 76.96}, {"w": "was", "s": 76.96, "e": 77.18}, {"w": "like", "s": 77.18, "e": 77.46}, {"w": "I", "s": 77.46, "e": 77.7}, {"w": "was", "s": 77.7, "e": 77.9}, {"w": "in", "s": 77.9, "e": 78.08}, {"w": "heaven.", "s": 78.08, "e": 78.4}]}, {"start": 81.5, "end": 83.5, "text": "My desk is made of wood.", "words": [{"w": "My", "s": 81.5, "e": 82.14}, {"w": "desk", "s": 82.14, "e": 82.52}, {"w": "is", "s": 82.52, "e": 82.76}, {"w": "made", "s": 82.76, "e": 82.98}, {"w": "of", "s": 82.98, "e": 83.18}, {"w": "wood.", "s": 83.18, "e": 83.5}]}, {"start": 86.32, "end": 88.7, "text": "The land is covered with snow.", "words": [{"w": "The", "s": 86.32, "e": 87.08}, {"w": "land", "s": 87.08, "e": 87.38}, {"w": "is", "s": 87.38, "e": 87.62}, {"w": "covered", "s": 87.62, "e": 87.96}, {"w": "with", "s": 87.96, "e": 88.3}, {"w": "snow.", "s": 88.3, "e": 88.7}]}, {"start": 91.64, "end": 94.46, "text": "People often hide their true feelings.", "words": [{"w": "People", "s": 91.64, "e": 92.4}, {"w": "often", "s": 92.4, "e": 92.86}, {"w": "hide", "s": 92.86, "e": 93.28}, {"w": "their", "s": 93.28, "e": 93.54}, {"w": "true", "s": 93.54, "e": 93.92}, {"w": "feelings.", "s": 93.92, "e": 94.46}]}, {"start": 97.64, "end": 99.56, "text": "She is dressed in silk.", "words": [{"w": "She", "s": 97.64, "e": 98.22}, {"w": "is", "s": 98.22, "e": 98.46}, {"w": "dressed", "s": 98.46, "e": 98.8}, {"w": "in", "s": 98.8, "e": 99.16}, {"w": "silk.", "s": 99.16, "e": 99.56}]}, {"start": 102.42, "end": 106.28, "text": "I usually stay up later on Friday and Saturday nights.", "words": [{"w": "I", "s": 102.42, "e": 103.04}, {"w": "usually", "s": 103.04, "e": 103.44}, {"w": "stay", "s": 103.44, "e": 103.88}, {"w": "up", "s": 103.88, "e": 104.16}, {"w": "later", "s": 104.16, "e": 104.42}, {"w": "on", "s": 104.42, "e": 104.76}, {"w": "Friday", "s": 104.76, "e": 105.12}, {"w": "and", "s": 105.12, "e": 105.46}, {"w": "Saturday", "s": 105.46, "e": 105.86}, {"w": "nights.", "s": 105.86, "e": 106.28}]}, {"start": 109.32, "end": 111.5, "text": "What have you learned in this class?", "words": [{"w": "What", "s": 109.32, "e": 110.08}, {"w": "have", "s": 110.08, "e": 110.3}, {"w": "you", "s": 110.3, "e": 110.44}, {"w": "learned", "s": 110.44, "e": 110.8}, {"w": "in", "s": 110.8, "e": 111.0}, {"w": "this", "s": 111.0, "e": 111.2}, {"w": "class?", "s": 111.2, "e": 111.5}]}, {"start": 114.56, "end": 117.68, "text": "It took her two years to master the language.", "words": [{"w": "It", "s": 114.56, "e": 115.2}, {"w": "took", "s": 115.2, "e": 115.44}, {"w": "her", "s": 115.44, "e": 115.66}, {"w": "two", "s": 115.66, "e": 115.9}, {"w": "years", "s": 115.9, "e": 116.28}, {"w": "to", "s": 116.28, "e": 116.6}, {"w": "master", "s": 116.6, "e": 117.0}, {"w": "the", "s": 117.0, "e": 117.26}, {"w": "language.", "s": 117.26, "e": 117.68}]}, {"start": 120.74, "end": 123.06, "text": "She presented a paper on physics.", "words": [{"w": "She", "s": 120.74, "e": 121.38}, {"w": "presented", "s": 121.38, "e": 121.88}, {"w": "a", "s": 121.88, "e": 122.12}, {"w": "paper", "s": 122.12, "e": 122.44}, {"w": "on", "s": 122.44, "e": 122.74}, {"w": "physics.", "s": 122.74, "e": 123.06}]}, {"start": 126.22, "end": 128.64, "text": "Could I have a sheet of paper, please?", "words": [{"w": "Could", "s": 126.22, "e": 126.86}, {"w": "I", "s": 126.86, "e": 127.08}, {"w": "have", "s": 127.08, "e": 127.34}, {"w": "a", "s": 127.34, "e": 127.5}, {"w": "sheet", "s": 127.5, "e": 127.74}, {"w": "of", "s": 127.74, "e": 127.9}, {"w": "paper,", "s": 127.9, "e": 128.22}, {"w": "please?", "s": 128.26, "e": 128.64}]}, {"start": 131.82, "end": 134.24, "text": "Please look carefully at this document.", "words": [{"w": "Please", "s": 131.82, "e": 132.46}, {"w": "look", "s": 132.46, "e": 132.78}, {"w": "carefully", "s": 132.78, "e": 133.28}, {"w": "at", "s": 133.28, "e": 133.6}, {"w": "this", "s": 133.6, "e": 133.78}, {"w": "document.", "s": 133.78, "e": 134.24}]}, {"start": 137.36, "end": 141.5, "text": "Today there are many vegetables that are easy to grow at home.", "words": [{"w": "Today", "s": 137.36, "e": 138.0}, {"w": "there", "s": 138.0, "e": 138.4}, {"w": "are", "s": 138.4, "e": 138.6}, {"w": "many", "s": 138.6, "e": 138.9}, {"w": "vegetables", "s": 138.9, "e": 139.42}, {"w": "that", "s": 139.42, "e": 139.94}, {"w": "are", "s": 139.94, "e": 140.08}, {"w": "easy", "s": 140.08, "e": 140.46}, {"w": "to", "s": 140.46, "e": 140.72}, {"w": "grow", "s": 140.72, "e": 141.0}, {"w": "at", "s": 141.0, "e": 141.18}, {"w": "home.", "s": 141.18, "e": 141.5}]}]