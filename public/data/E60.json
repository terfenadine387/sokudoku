[{"start": 0.0, "end": 1.76, "text": "It is time to act.", "words": [{"w": "It", "s": 0.0, "e": 0.6}, {"w": "is", "s": 0.6, "e": 0.78}, {"w": "time", "s": 0.78, "e": 1.12}, {"w": "to", "s": 1.12, "e": 1.38}, {"w": "act.", "s": 1.38, "e": 1.76}]}, {"start": 4.54, "end": 7.06, "text": "How did they react to the news?", "words": [{"w": "How", "s": 4.54, "e": 5.36}, {"w": "did", "s": 5.36, "e": 5.56}, {"w": "they", "s": 5.56, "e": 5.78}, {"w": "react", "s": 5.78, "e": 6.26}, {"w": "to", "s": 6.26, "e": 6.54}, {"w": "the", "s": 6.54, "e": 6.68}, {"w": "news?", "s": 6.68, "e": 7.06}]}, {"start": 9.84, "end": 11.92, "text": "He has a gentle heart.", "words": [{"w": "He", "s": 9.84, "e": 10.66}, {"w": "has", "s": 10.66, "e": 10.96}, {"w": "a", "s": 10.96, "e": 11.16}, {"w": "gentle", "s": 11.16, "e": 11.46}, {"w": "heart.", "s": 11.46, "e": 11.92}]}, {"start": 15.4, "end": 17.82, "text": "I felt the strong shock of the earthquake.", "words": [{"w": "I", "s": 15.17, "e": 15.58}, {"w": "felt", "s": 15.58, "e": 15.9}, {"w": "the", "s": 15.9, "e": 16.16}, {"w": "strong", "s": 16.16, "e": 16.58}, {"w": "shock", "s": 16.58, "e": 17.0}, {"w": "of", "s": 17.0, "e": 17.26}, {"w": "the", "s": 17.26, "e": 17.42}, {"w": "earthquake.", "s": 17.42, "e": 17.82}]}, {"start": 20.58, "end": 24.08, "text": "He was deeply shocked by his dog's sudden death.", "words": [{"w": "He", "s": 20.58, "e": 21.4}, {"w": "was", "s": 21.4, "e": 21.6}, {"w": "deeply", "s": 21.6, "e": 21.92}, {"w": "shocked", "s": 21.92, "e": 22.38}, {"w": "by", "s": 22.38, "e": 22.68}, {"w": "his", "s": 22.68, "e": 22.9}, {"w": "dog's", "s": 22.9, "e": 23.36}, {"w": "sudden", "s": 23.36, "e": 23.62}, {"w": "death.", "s": 23.62, "e": 24.08}]}, {"start": 26.9, "end": 29.26, "text": "Children easily absorbed knowledge.", "words": [{"w": "Children", "s": 26.9, "e": 27.72}, {"w": "easily", "s": 27.72, "e": 28.22}, {"w": "absorbed", "s": 28.22, "e": 28.7}, {"w": "knowledge.", "s": 28.7, "e": 29.26}]}, {"start": 32.14, "end": 35.92, "text": "His company specialized in developing wasteland.", "words": [{"w": "His", "s": 32.14, "e": 32.98}, {"w": "company", "s": 32.98, "e": 33.38}, {"w": "specialized", "s": 33.38, "e": 34.04}, {"w": "in", "s": 34.04, "e": 34.48}, {"w": "developing", "s": 34.48, "e": 34.98}, {"w": "wasteland.", "s": 34.98, "e": 35.92}]}, {"start": 39.02, "end": 42.98, "text": "Africa is rich in minerals such as gold and diamonds.", "words": [{"w": "Africa", "s": 39.02, "e": 39.86}, {"w": "is", "s": 39.86, "e": 40.36}, {"w": "rich", "s": 40.36, "e": 40.68}, {"w": "in", "s": 40.68, "e": 40.88}, {"w": "minerals", "s": 40.88, "e": 41.28}, {"w": "such", "s": 41.28, "e": 41.72}, {"w": "as", "s": 41.72, "e": 41.94}, {"w": "gold", "s": 41.94, "e": 42.26}, {"w": "and", "s": 42.26, "e": 42.56}, {"w": "diamonds.", "s": 42.56, "e": 42.98}]}, {"start": 45.96, "end": 49.98, "text": "There are some birds which build their nests among the rocks.", "words": [{"w": "There", "s": 45.96, "e": 46.8}, {"w": "are", "s": 46.8, "e": 46.96}, {"w": "some", "s": 46.96, "e": 47.28}, {"w": "birds", "s": 47.28, "e": 47.68}, {"w": "which", "s": 47.68, "e": 47.96}, {"w": "build", "s": 47.96, "e": 48.28}, {"w": "their", "s": 48.28, "e": 48.52}, {"w": "nests", "s": 48.52, "e": 48.94}, {"w": "among", "s": 48.94, "e": 49.34}, {"w": "the", "s": 49.34, "e": 49.6}, {"w": "rocks.", "s": 49.6, "e": 49.98}]}, {"start": 52.8, "end": 57.3, "text": "The children constructed a model castle from cardboard boxes.", "words": [{"w": "The", "s": 52.8, "e": 53.64}, {"w": "children", "s": 53.64, "e": 54.04}, {"w": "constructed", "s": 54.04, "e": 54.76}, {"w": "a", "s": 54.76, "e": 55.0}, {"w": "model", "s": 55.0, "e": 55.26}, {"w": "castle", "s": 55.26, "e": 55.8}, {"w": "from", "s": 55.8, "e": 56.24}, {"w": "cardboard", "s": 56.24, "e": 56.72}, {"w": "boxes.", "s": 56.72, "e": 57.3}]}, {"start": 61.0, "end": 63.0, "text": "Our company was established in 1931.", "words": [{"w": "Our", "s": 60.68, "e": 61.08}, {"w": "company", "s":