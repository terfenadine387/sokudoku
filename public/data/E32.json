[{"start": 0.0, "end": 3.56, "text": "I think there is a link between poverty and disease.", "words": [{"w": "I", "s": 0.0, "e": 0.64}, {"w": "think", "s": 0.64, "e": 0.88}, {"w": "there", "s": 0.88, "e": 1.16}, {"w": "is", "s": 1.16, "e": 1.34}, {"w": "a", "s": 1.34, "e": 1.48}, {"w": "link", "s": 1.48, "e": 1.78}, {"w": "between", "s": 1.78, "e": 2.2}, {"w": "poverty", "s": 2.2, "e": 2.66}, {"w": "and", "s": 2.66, "e": 3.16}, {"w": "disease.", "s": 3.16, "e": 3.56}]}, {"start": 6.5, "end": 9.5, "text": "This is actually the most important reason.", "words": [{"w": "This", "s": 6.5, "e": 7.32}, {"w": "is", "s": 7.32, "e": 7.5}, {"w": "actually", "s": 7.5, "e": 7.98}, {"w": "the", "s": 7.98, "e": 8.26}, {"w": "most", "s": 8.26, "e": 8.54}, {"w": "important", "s": 8.54, "e": 9.08}, {"w": "reason.", "s": 9.08, "e": 9.5}]}, {"start": 12.56, "end": 13.7, "text": "That's true.", "words": [{"w": "That's", "s": 12.56, "e": 13.38}, {"w": "true.", "s": 13.38, "e": 13.7}]}, {"start": 16.74, "end": 19.7, "text": "I usually read before I go to bed.", "words": [{"w": "I", "s": 16.74, "e": 17.18}, {"w": "usually", "s": 17.18, "e": 17.68}, {"w": "read", "s": 17.68, "e": 18.26}, {"w": "before", "s": 18.26, "e": 18.74}, {"w": "I", "s": 18.74, "e": 19.04}, {"w": "go", "s": 19.04, "e": 19.24}, {"w": "to", "s": 19.24, "e": 19.42}, {"w": "bed.", "s": 19.42, "e": 19.7}]}, {"start": 22.6, "end": 24.76, "text": "I agree with you on that.", "words": [{"w": "I", "s": 22.6, "e": 23.42}, {"w": "agree", "s": 23.42, "e": 23.72}, {"w": "with", "s": 23.72, "e": 24.02}, {"w": "you", "s": 24.02, "e": 24.24}, {"w": "on", "s": 24.24, "e": 24.46}, {"w": "that.", "s": 24.46, "e": 24.76}]}, {"start": 27.66, "end": 30.46, "text": "I'm afraid I have to disagree with you.", "words": [{"w": "I'm", "s": 27.66, "e": 28.4}, {"w": "afraid", "s": 28.4, "e": 28.72}, {"w": "I", "s": 28.72, "e": 28.98}, {"w": "have", "s": 28.98, "e": 29.22}, {"w": "to", "s": 29.22, "e": 29.44}, {"w": "disagree", "s": 29.44, "e": 29.