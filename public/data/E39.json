[{"start": 0.0, "end": 2.0, "text": "He played a major role.", "words": [{"w": "He", "s": 0.0, "e": 0.6}, {"w": "played", "s": 0.6, "e": 0.92}, {"w": "a", "s": 0.92, "e": 1.12}, {"w": "major", "s": 1.12, "e": 1.42}, {"w": "role.", "s": 1.42, "e": 2.0}]}, {"start": 4.84, "end": 8.0, "text": "Luckily, I received only minor injuries.", "words": [{"w": "Luckily,", "s": 4.84, "e": 5.66}, {"w": "I", "s": 6.08, "e": 6.26}, {"w": "received", "s": 6.26, "e": 6.66}, {"w": "only", "s": 6.66, "e": 7.02}, {"w": "minor", "s": 7.02, "e": 7.4}, {"w": "injuries.", "s": 7.4, "e": 8.0}]}, {"start": 10.84, "end": 14.58, "text": "A key proposal is to eliminate school uniforms.", "words": [{"w": "A", "s": 10.84, "e": 11.66}, {"w": "key", "s": 11.66, "e": 11.88}, {"w": "proposal", "s": 11.88, "e": 12.36}, {"w": "is", "s": 12.36, "e": 12.78}, {"w": "to", "s": 12.78, "e": 12.98}, {"w": "eliminate", "s": 12.98, "e": 13.42}, {"w": "school", "s": 13.42, "e": 13.9}, {"w": "uniforms.", "s": 13.9, "e": 14.58}]}, {"start": 18.0, "end": 21.02, "text": "I bought the novel simply because I liked the movie.", "words": [{"w": "I", "s": 17.81, "e": 18.22}, {"w": "bought", "s": 18.22, "e": 18.44}, {"w": "the", "s": 18.44, "e": 18.66}, {"w": "novel", "s": 18.66, "e": 18.98}, {"w": "simply", "s": 18.98, "e": 19.5}, {"w": "because", "s": 19.5, "e": 19.9}, {"w": "I", "s": 19.9, "e": 20.14}, {"w": "liked", "s": 20.14, "e": 20.46}, {"w": "the", "s": 20.46, "e": 20.72}, {"w": "movie.", "s": 20.72, "e": 21.02}]}, {"start": 23.94, "end": 26.76, "text": "I have lived here since I was a child.", "words": [{"w": "I", "s": 23.94, "e": 24.66}, {"w": "have", "s": 24.66, "e": 24.88}, {"w": "lived", "s": 24.88, "e": 25.12}, {"w": "here", "s": 25.12, "e": 25.46}, {"w": "since", "s": 25.46, "e": 25.82}, {"w": "I", "s": 25.82, "e": 26.06}, {"w": "was", "s": 26.06, "e": 26.24}, {"w": "a", "s": 26.24, "e": 26.42}, {"w": "child.", "s": 26.42, "e": 26.76}]}, {"start": 29.56, "end": 33.28, "text": "We saw a Japanese drum performance at the festival.", "words": [{"w": "We", "s": 29.56, "e": 30.28}, {"w": "saw", "s": 30.28, "e": 30.64}, {"w": "a", "s": 30.64, "e": 30.86}, {"w": "Japanese", "s": 30.86, "e": 31.2}, {"w": "drum", "s": 31.2, "e": 31.66}, {"w": "performance", "s": 31.66, "e": 32.34}, {"w": "at", "s": 32.34, "e": 32.66}, {"w": "the", "s": 32.66, "e": 32.8}, {"w": "festival.", "s": 32.8, "e": 33.28}]}, {"start": 36.38, "end": 39.36, "text": "She is able to speak French very well.", "words": [{"w": "She", "s": 36.38, "e": 37.0}, {"w": "is", "s": 37.0, "e": 37.22}, {"w": "able", "s": 37.22, "e": 37.48}, {"w": "to", "s": 37.48, "e": 37.7}, {"w": "speak", "s": 37.7, "e": 37.98}, {"w": "French", "s": 37.98, "e": 38.52}, {"w": "very", "s": 38.52, "e": 38.88}, {"w": "well.", "s": 38.88, "e": 39.36}]}, {"start": 42.42, "end": 45.28, "text": "His ability to speak English is not bad.", "words": [{"w": "His", "s": 42.42, "e": 42.84}, {"w": "ability", "s": 42.84, "e": 43.2}, {"w": "to", "s": 43.2, "e": 43.58}, {"w": "speak", "s": 43.58, "e": 43.84}, {"w": "English", "s": 43.84, "e": 44.3}, {"w": "is", "s": 44.3, "e": 44.64}, {"w": "not", "s": 44.64, "e": 44.9}, {"w": "bad.", "s": 44.9, "e": 45.28}]}, {"start": 48.18, "end": 50.98, "text": "I am sorry I am unable to come.", "words": [{"w": "I", "s": 48.18, "e": 48.86}, {"w": "am", "s": 48.86, "e": 49.02}, {"w": "sorry", "s": 49.02, "e": 49.48}, {"w": "I", "s": 49.48, "e": 49.86}, {"w": "am", "s": 49.86, "e": 50.0}, {"w": "unable", "s": 50.0, "e": 50.32}, {"w": "to", "s": 50.32, "e": 50.6}, {"w": "come.", "s": 50.6, "e": 50.98}]}, {"start": 53.86, "end": 58.68, "text": "The new series will be available to watch from October 14th.", "words": [{"w": "The", "s": 53.86, "e": 54.54}, {"w": "new", "s": 54.54, "e": 54.76}, {"w": "series", "s": 54.76, "e": 55.22}, {"w": "will", "s": 55.22, "e": 55.54}, {"w": "be", "s": 55.54, "e": 55.72}, {"w": "available", "s": 55.72, "e": 56.14}, {"w": "to", "s": 56.14, "e": 56.48}, {"w": "watch", "s": 56.48, "e": 56.