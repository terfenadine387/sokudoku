[{"start": 0.0, "end": 2.24, "text": "Your arguments are contradictory.", "words": [{"w": "Your", "s": 0.0, "e": 0.7}, {"w": "arguments", "s": 0.7, "e": 1.24}, {"w": "are", "s": 1.24, "e": 1.6}, {"w": "contradictory.", "s": 1.6, "e": 2.24}]}, {"start": 5.52, "end": 8.84, "text": "This is exactly why we need to change our leaders.", "words": [{"w": "This", "s": 5.52, "e": 6.16}, {"w": "is", "s": 6.16, "e": 6.34}, {"w": "exactly", "s": 6.34, "e": 6.9}, {"w": "why", "s": 6.9, "e": 7.26}, {"w": "we", "s": 7.26, "e": 7.48}, {"w": "need", "s": 7.48, "e": 7.7}, {"w": "to", "s": 7.7, "e": 7.9}, {"w": "change", "s": 7.9, "e": 8.2}, {"w": "our", "s": 8.2, "e": 8.48}, {"w": "leaders.", "s": 8.48, "e": 8.84}]}, {"start": 11.92, "end": 16.06, "text": "I think that is precisely the reason for making a new choice.", "words": [{"w": "I", "s": 11.92, "e": 12.56}, {"w": "think", "s": 12.56, "e": 12.8}, {"w": "that", "s": 12.8, "e": 13.02}, {"w": "is", "s": 13.02, "e": 13.22}, {"w": "precisely", "s": 13.22, "e": 13.84}, {"w": "the", "s": 13.84, "e": 14.14}, {"w": "reason", "s": 14.14, "e": 14.52}, {"w": "for", "s": 14.52, "e": 14.82}, {"w": "making", "s": 14.82, "e": 15.14}, {"w": "a", "s": 15.14, "e": 15.42}, {"w": "new", "s": 15.42, "e": 15.6}, {"w": "choice.", "s": 15.6, "e": 16.06}]}, {"start": 19.06, "end": 22.64, "text": "We definitely need to think about how to fix the problem.", "words": [{"w": "We", "s": 19.06, "e": 19.7}, {"w": "definitely", "s": 19.7, "e": 20.12}, {"w": "need", "s": 20.12, "e": 20.6}, {"w": "to", "s": 20.6, "e": 20.82}, {"w": "think", "s": 20.82, "e": 21.02}, {"w": "about", "s": 21.02, "e": 21.3}, {"w": "how", "s": 21.3, "e": 21.56}, {"w": "to", "s": 21.56, "e": 21.74}, {"w": "fix", "s": 21.74, "e": 21.98}, {"w": "the", "s": 21.98, "e": 22.22}, {"w": "problem.", "s": 22.22, "e": 22.64}]}, {"start": 25.72, "end": 28.8, "text": "My opinion is just the opposite of yours.", "words": [{"w": "My", "s": 25.72, "e": 26.32}, {"w": "opinion", "s": 26.32, "e": 26.7}, 