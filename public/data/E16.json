[{"start": 0.0, "end": 2.14, "text": "It's lucky that we met here.", "words": [{"w": "It's", "s": 0.0, "e": 0.7}, {"w": "lucky", "s": 0.7, "e": 1.0}, {"w": "that", "s": 1.0, "e": 1.3}, {"w": "we", "s": 1.3, "e": 1.48}, {"w": "met", "s": 1.48, "e": 1.72}, {"w": "here.", "s": 1.72, "e": 2.14}]}, {"start": 4.98, "end": 8.32, "text": "You are very fortunate to have a lot of good friends.", "words": [{"w": "You", "s": 4.98, "e": 5.62}, {"w": "are", "s": 5.62, "e": 5.74}, {"w": "very", "s": 5.74, "e": 6.02}, {"w": "fortunate", "s": 6.02, "e": 6.58}, {"w": "to", "s": 6.58, "e": 6.9}, {"w": "have", "s": 6.9, "e": 7.14}, {"w": "a", "s": 7.14, "e": 7.28}, {"w": "lot", "s": 7.28, "e": 7.46}, {"w": "of", "s": 7.46, "e": 7.64}, {"w": "good", "s": 7.64, "e": 7.84}, {"w": "friends.", "s": 7.84, "e": 8.32}]}, {"start": 11.36, "end": 13.48, "text": "They often fought each other.", "words": [{"w": "They", "s": 11.36, "e": 12.0}, {"w": "often", "s": 12.0, "e": 12.46}, {"w": "fought", "s": 12.46, "e": 12.82}, {"w": "each", "s": 12.82, "e": 13.16}, {"w": "other.", "s": 13.16, "e": 13.48}]}, {"start": 16.42, "end": 18.6, "text": "What do you think of my proposal?", "words": [{"w": "What", "s": 16.42, "e": 17.06}, {"w": "do", "s": 17.06, "e": 17.24}, {"w": "you", "s": 17.24, "e": 17.38}, {"w": "think", "s": 17.38, "e": 17.68}, {"w": "of", "s": 17.68, "e": 17.88}, {"w": "my", "s": 17.88, "e": 18.08}, {"w": "proposal?", "s": 18.08, "e": 18.6}]}, {"start": 21.62, "end": 24.04, "text": "Is she coming? I guess so.", "words": [{"w": "Is", "s": 21.62, "e": 22.26}, {"w": "she", "s": 22.26, "e": 22.44}, {"w": "coming?", "s": 22.44, "e": 22.72}, {"w": "I", "s": 23.28, "e": 23.48}, {"w": "guess", "s": 23.48, "e": 23.7}, {"w": "so.", "s": 23.7, "e": 24.04}]}, {"start": 26.74, "end": 28.62, "text": "I suppose he's right.", "words": [{"w": "I", "s": 26.74, "e": 27.54}, {"w": "suppose", "s": 27.54, "e": 27.94}, {"w": "he's", "s": 27.94, "e": 28.34}, {"w": "right.", "s": 28.34, "e": 28.62}]}, {"start": 31.5, "end": 34.36, "text": "Please don't assume that I know the answer.", "words": [{"w": "Please", "s": 31.5, "e": 32.3}, {"w": "don't", "s": 32.3, "e": 32.68}, {"w": "assume", "s": 32.68, "e": 33.06}, {"w": "that", "s": 33.06, "e": 33.36}, {"w": "I", "s": 33.36, "e": 33.54}, {"w": "know", "s": 33.54, "e": 33.78}, {"w": "the", "s": 33.78, "e": 33.98}, {"w": "answer.", "s": 33.98, "e": 34.36}]}, {"start": 37.24, "end": 40.18, "text": "She can't imagine living without music.", "words": [{"w": "She", "s": 37.24, "e": 38.04}, {"w": "can't", "s": 38.04, "e": 38.42}, {"w": "imagine", "s": 38.42, "e": 38.84}, {"w": "living", "s": 38.84, "e": 39.2}, {"w": "without", "s": 39.2, "e": 39.7}, {"w": "music.", "s": 39.7, "e": 40.18}]}, {"start": 43.04, "end": 46.58, "text": "It is sometimes difficult to pronounce English words.", "words": [{"w": "It", "s": 43.04, "e": 43.78}, {"w": "is", "s": 43.78, "e": 43.92}, {"w": "sometimes", "s": 43.92, "e": 44.28}, {"w": "difficult", "s": 44.28, "e": 44.9}, {"w": "to", "s": 44.9, "e": 45.24}, {"w": "pronounce", "s": 45.24, "e": 45.56}, {"w": "English", "s": 45.56, "e": 46.0}, {"w": "words.", "s": 46.0, "e": 46.58}]}, {"start": 49.42, "end": 51.86, "text": "I was surprised at his death.", "words": [{"w": "I", "s": 49.42, "e": 50.22}, {"w": "was", "s": 50.22, "e": 50.42}, {"w": "surprised", "s": 50.42, "e": 50.9}, {"w": "at", "s": 50.9, "e": 51.22}, {"w": "his", "s": 51.22, "e": 51.42}, {"w": "death.", "s": 51.42, "e": 51.86}]}, {"start": 54.58, "end": 57.26, "text": "A famous writer is buried here.", "words": [{"w": "A", "s": 54.58, "e": 55.38}, {"w": "famous", "s": 55.38, "e": 55.72}, {"w": "writer", "s": 55.72, "e": 56.2}, {"w": "is", "s": 56.2, "e": 56.54}, {"w": "buried", "s": 56.54, "e": 56.86}, {"w": "here.", "s": 56.86, "e": 57.26}]}, {"start": 60.06, "end": 62.18, "text": "Could you give me some examples?", "words": [{"w": "Could", "s": 60.06, "e": 60.86}, {"w": "you", "s": 60.86, "e": 61.06}, {"w": "give", "s": 61.06, "e": 61.28},