[{"start": 0.0, "end": 3.2, "text": "He suffered a serious injury in the accident.", "words": [{"w": "He", "s": 0.0, "e": 0.58}, {"w": "suffered", "s": 0.58, "e": 1.0}, {"w": "a", "s": 1.0, "e": 1.24}, {"w": "serious", "s": 1.24, "e": 1.62}, {"w": "injury", "s": 1.62, "e": 2.24}, {"w": "in", "s": 2.24, "e": 2.48}, {"w": "the", "s": 2.48, "e": 2.62}, {"w": "accident.", "s": 2.62, "e": 3.2}]}, {"start": 5.94, "end": 7.52, "text": "Are you serious?", "words": [{"w": "Are", "s": 5.94, "e": 6.76}, {"w": "you", "s": 6.76, "e": 6.98}, {"w": "serious?", "s": 6.98, "e": 7.52}]}, {"start": 10.52, "end": 14.78, "text": "My father has suffered from heart disease for 10 years.", "words": [{"w": "My", "s": 10.52, "e": 11.34}, {"w": "father", "s": 11.34, "e": 11.74}, {"w": "has", "s": 11.74, "e": 12.14}, {"w": "suffered", "s": 12.14, "e": 12.56}, {"w": "from", "s": 12.56, "e": 12.88}, {"w": "heart", "s": 12.88, "e": 13.2}, {"w": "disease", "s": 13.2, "e": 13.62}, {"w": "for", "s": 13.62, "e": 14.06}, {"w": "10", "s": 14.06, "e": 14.42}, {"w": "years.", "s": 14.42, "e": 14.78}]}, {"start": 17.66, "end": 20.32, "text": "I have a poor sense of direction.", "words": [{"w": "I", "s": 17.66, "e": 18.48}, {"w": "have", "s": 18.48, "e": 18.74}, {"w": "a", "s": 18.74, "e": 18.92}, {"w": "poor", "s": 18.92, "e": 19.24}, {"w": "sense", "s": 19.24, "e": 19.56}, {"w": "of", "s": 19.56, "e": 19.8}, {"w": "direction.", "s": 19.8, "e": 20.32}]}, {"start": 23.2, "end": 26.94, "text": "Rich countries should do more to help poor ones.", "words": [{"w": "Rich", "s": 23.2, "e": 23.98}, {"w": "countries", "s": 23.98, "e": 24.6}, {"w": "should", "s": 24.6, "e": 25.04}, {"w": "do", "s": 25.04, "e": 25.26}, {"w": "more", "s": 25.26, "e": 25.58}, {"w": "to", "s": 25.58, "e": 25.86}, {"w": "help", "s": 25.86, "e": 26.14}, {"w": "poor", "s": 26.14, "e": 26.52}, {"w": "ones.", "s": 26.52, "e": 26.94}]}, {"start": 29.82, "end": 33.24, "text": "Hot springs are extremely abundant in Japan.", "words": [{"w": "Hot", "s": 29.82, "e": 30.6}, {"w": "springs", "s": 30.6, "e": 30.9}, {"w": "are", "s": 30.9, "e": 31.32}, {"w": "extremely", "s": 31.32, "e": 31.82}, {"w": "abundant", "s": 31.82, "e": 32.42}, {"w": "in", "s": 32.42, "e": 32.8}, {"w": "Japan.", "s": 32.8, "e": 33.24}]}, {"start": 36.1, "end": 39.76, "text": "It is fair that wealthy citizens pay more taxes.", "words": [{"w": "It", "s": 36.1, "e": 36.88}, {"w": "is", "s": 36.88, "e": 37.06}, {"w": "fair", "s": 37.06, "e": 37.36}, {"w": "that", "s": 37.36, "e": 37.7}, {"w": "wealthy", "s": 37.7, "e": 38.06}, {"w": "citizens", "s": 38.06, "e": 38.7}, {"w": "pay", "s": 38.7, "e": 39.08}, {"w": "more", "s": 39.08, "e": 39.3}, {"w": "taxes.", "s": 39.3, "e": 39.76}]}, {"start": 42.74, "end": 45.62, "text": "There is a lot of wildlife in the forest.", "words": [{"w": "There", "s": 42.74, "e": 43.52}, {"w": "is", "s": 43.52, "e": 43.7}, {"w": "a", "s": 43.7, "e": 43.88}, {"w": "lot", "s": 43.88, "e": 44.06}, {"w": "of", "s": 44.06, "e": 44.26}, {"w": "wildlife", "s": 44.26, "e": 44.76}, {"w": "in", "s": 44.76, "e": 45.16}, {"w": "the", "s": 45.16, "e": 45.28}, {"w": "forest.", "s": 45.28, "e": 45.62}]}, {"start": 47.74, "end": 49.16, "text": "Thank you for watching.", "words": [{"w": "Thank", "s": 47.74, "e": 49.14}, {"w": "you", "s": 49.14, "e": 49.16}, {"w": "for", "s": 49.16, "e": 49.16}, {"w": "watching.", "s": 49.16, "e": 49.16}]}]