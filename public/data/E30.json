start": 142.62, "end": 144.7, "text": "Please hold the end of this rope.", "words": [{"w": "Please", "s": 142.62, "e": 143.26}, {"w": "hold", "s": 143.26, "e": 143.64}, {"w": "the", "s": 143.64, "e": 143.84}, {"w": "end", "s": 143.84, "e": 144.06}, {"w": "of", "s": 144.06, "e": 144.18}, {"w": "this", "s": 144.18, "e": 144.42}, {"w": "rope.", "s": 144.42, "e": 144.7}]}, {"start": 147.56, "end": 149.82, "text": "She holds a party every day.", "words": [{"w": "She", "s": 147.56, "e": 148.32}, {"w": "holds", "s": 148.32, "e": 148.58}, {"w": "a", "s": 148.58, "e": 148.72}, {"w": "party", "s": 148.72, "e": 149.1}, {"w": "every", "s": 149.1, "e": 149.48}, {"w": "day.", "s": 149.48, "e": 149.82}]}]