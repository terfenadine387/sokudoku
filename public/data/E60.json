8, "e": 93.36}, {"w": "flexible", "s": 93.36, "e": 93.84}, {"w": "when", "s": 93.84, "e": 94.28}, {"w": "making", "s": 94.28, "e": 94.72}, {"w": "an", "s": 94.72, "e": 94.94}, {"w": "agreement.", "s": 94.94, "e": 95.32}]}, {"start": 99.0, "end": 101.12, "text": "The wind feels cold on my skin.", "words": [{"w": "The", "s": 98.66, "e": 99.04}, {"w": "wind", "s": 99.04, "e": 99.38}, {"w": "feels", "s": 99.38, "e": 99.74}, {"w": "cold", "s": 99.74, "e": 100.22}, {"w": "on", "s": 100.22, "e": 100.5}, {"w": "my", "s": 100.5, "e": 100.72}, {"w": "skin.", "s": 100.72, "e": 101.12}]}, {"start": 104.0, "end": 106.58, "text": "She held her father's hand tightly.", "words": [{"w": "She", "s": 104.0, "e": 104.76}, {"w": "held", "s": 104.76, "e": 105.08}, {"w": "her", "s": 105.08, "e": 105.3}, {"w": "father's", "s": 105.3, "e": 105.86}, {"w": "hand", "s": 105.86, "e": 106.1}, {"w": "tightly.", "s": 106.1, "e": 106.58}]}, {"start": 109.52, "end": 112.82, "text": "She felt that the coat was tight under the arms.", "words": [{"w": "She", "s": 109.52, "e": 110.28}, {"w": "felt", "s": 110.28, "e": 110.62}, {"w": "that", "s": 110.62, "e": 110.9}, {"w": "the", "s": 110.9, "e": 111.02}, {"w": "coat", "s": 111.02, "e": 111.3}, {"w": "was", "s": 111.3, "e": 111.58}, {"w": "tight", "s": 111.58, "e": 111.9}, {"w": "under", "s": 111.9, "e": 112.24}, {"w": "the", "s": 112.24, "e": 112.44}, {"w": "arms.", "s": 112.44, "e": 112.82}]}, {"start": 115.98, "end": 118.9, "text": "Several labels were attached to the box.", "words": [{"w": "Several", "s": 115.98, "e": 116.74}, {"w": "labels", "s": 116.74, "e": 117.22}, {"w": "were", "s": 117.22, "e": 117.64}, {"w": "attached", "s": 117.64, "e": 117.94}, {"w": "to", "s": 117.94, "e": 118.38}, {"w": "the", "s": 118.38, "e": 118.48}, {"w": "box.", "s": 118.48, "e": 118.9}]}, {"start": 120.96, "end": 122.36, "text": "Its volume and amount seemed to make the cold rain reach my original surroundings.", "words": [{"w": "Its", "s": 120.96, "e": 122.36}, {"w":