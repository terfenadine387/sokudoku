[{"start": 0.0, "end": 2.42, "text": "Be careful not to spill the water.", "words": [{"w": "Be", "s": 0.0, "e": 0.66}, {"w": "careful", "s": 0.66, "e": 1.06}, {"w": "not", "s": 1.06, "e": 1.34}, {"w": "to", "s": 1.34, "e": 1.6}, {"w": "spill", "s": 1.6, "e": 1.86}, {"w": "the", "s": 1.86, "e": 2.12}, {"w": "water.", "s": 2.12, "e": 2.42}]}, {"start": 5.34, "end": 9.5, "text": "He is very rich. However, I won't marry him.", "words": [{"w": "He", "s": 5.34, "e": 6.02}, {"w": "is", "s": 6.02, "e": 6.22}, {"w": "very", "s": 6.22, "e": 6.56}, {"w": "rich.", "s": 6.56, "e": 7.04}, {"w": "However,", "s": 7.48, "e": 7.86}, {"w": "I", "s": 8.28, "e": 8.48}, {"w": "won't", "s": 8.48, "e": 8.84}, {"w": "marry", "s": 8.84, "e": 9.18}, {"w": "him.", "s": 9.18, "e": 9.5}]}, {"start": 12.56, "end": 15.42, "text": "However hard the work is, he will do it.", "words": [{"w": "However", "s": 12.56, "e": 13.24}, {"w": "hard", "s": 13.24, "e": 13.62}, {"w": "the", "s": 13.62, "e": 13.82}, {"w": "work", "s": 13.82, "e": 14.08}, {"w": "is,", "s": 14.08, "e": 14.42}, {"w": "he", "s": 14.68, "e": 14.8}, {"w": "will", "s": 14.8, "e": 14.98}, {"w": "do", "s": 14.98, "e": 15.18}, {"w": "it.", "s": 15.18, "e": 15.42}]}, {"start": 18.34, "end": 21.96, "text": "I'm willing to reverse my position on climate change.", "words": [{"w": "I'm", "s": 18.34, "e": 19.02}, {"w": "willing", "s": 19.02, "e": 19.26}, {"w": "to", "s": 19.26, "e": 19.54}, {"w": "reverse", "s": 19.54, "e": 19.94}, {"w": "my", "s": 19.94, "e": 20.26}, {"w": "position", "s": 20.26, "e": 20.72}, {"w": "on", "s": 20.72, "e": 21.04}, {"w": "climate", "s": 21.04, "e": 21.5}, {"w": "change.", "s": 21.5, "e": 21.96}]}, {"start": 24.98, "end": 26.82, "text": "Turn your face toward me.", "words": [{"w": "Turn", "s": 24.98, "e": 25.6}, {"w": "your", "s": 25.6, "e": 25.86}, {"w": "face", "s": 25.86, "e": 26.14}, {"w": "toward", "s": 26.14, "e": 26.52}, {"w": "me.", "s": 26.52, "e": 26.82}]}, {"start": 29.76, "end": 33.54, "text": "Turn right at the next corner, and you can see the city hall.", "words": [{"w": "Turn", "s": 29.76, "e": 30.38}, {"w": "right", "s": 30.38, "e": 30.7}, {"w": "at", "s": 30.7, "e": 30.94}, {"w": "the", "s": 30.94, "e": 31.04}, {"w": "next", "s": 31.04, "e": 31.28}, {"w": "corner,", "s": 31.28, "e": 31.72}, {"w": "and", "s": 32.02, "e": 32.28}, {"w": "you", "s": 32.28, "e": 32.42}, {"w": "can", "s": 32.42, "e": 32.58}, {"w": "see", "s": 32.58, "e": 32.8}, {"w": "the", "s": 32.8, "e": 32.98}, {"w": "city", "s": 32.98, "e": 33.2}, {"w": "hall.", "s": 33.2, "e": 33.54}]}, {"start": 36.5, "end": 38.7, "text": "The wind turned to the east.", "words": [{"w": "The", "s": 36.5, "e": 37.12}, {"w": "wind", "s": 37.12, "e": 37.46}, {"w": "turned", "s": 37.46, "e": 37.84}, {"w": "to", "s": 37.84, "e": 38.16}, {"w": "the", "s": 38.16, "e": 38.34}, {"w": "east.", "s": 38.34, "e": 38.7}]}, {"start": 41.68, "end": 44.04, "text": "This idea seems a little backward.", "words": [{"w": "This", "s": 41.68, "e": 42.3}, {"w": "idea", "s": 42.3, "e": 42.76}, {"w": "seems", "s": 42.76, "e": 43.2}, {"w": "a", "s": 43.2, "e": 43.42}, {"w": "little", "s": 43.42, "e": 43.6}, {"w": "backward.", "s": 43.6, "e": 44.04}]}, {"start": 47.34, "end": 49.9, "text": "Let's move the plan forward with a vote.", "words": [{"w": "Let's", "s": 47.34, "e": 47.96}, {"w": "move", "s": 47.96, "e": 48.2}, {"w": "the", "s": 48.2, "e": 48.42}, {"w": "plan", "s": 48.42, "e": 48.72}, {"w": "forward", "s": 48.72, "e": 49.22}, {"w": "with", "s": 49.22, "e": 49.52}, {"w": "a", "s": 49.52, "e": 49.66}, {"w": "vote.", "s": 49.66, "e": 49.9}]}, {"start": 52.92, "end": 54.54, "text": "I'll be back in a minute.", "words": [{"w": "I'll", "s": 52.92, "e": 53.56}, {"w": "be", "s": 53.56, "e": 53.7}, {"w": "back", "s": 53.7, "e": 53.98}, {"w": "in", "s": 53.98, "e": 54.16}, {"w": "a", "s": 54.16, "e": 54.28}, {"w": "minute.", "s": 54.28, "e": 54.54}]}, {"start": 57.54, "end": 59.88, "text": "Ann will return to London tonight.", "words": [{"