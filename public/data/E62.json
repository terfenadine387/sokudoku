[{"start": 0.0, "end": 2.36, "text": "She gave an excellent speech.", "words": [{"w": "She", "s": 0.0, "e": 0.7}, {"w": "gave", "s": 0.7, "e": 0.96}, {"w": "an", "s": 0.96, "e": 1.2}, {"w": "excellent", "s": 1.2, "e": 1.64}, {"w": "speech.", "s": 1.64, "e": 2.36}]}, {"start": 5.48, "end": 9.64, "text": "Studying in Paris will be a fantastic opportunity for Mika.", "words": [{"w": "Studying", "s": 5.48, "e": 6.2}, {"w": "in", "s": 6.2, "e": 6.4}, {"w": "Paris", "s": 6.4, "e": 6.76}, {"w": "will", "s": 6.76, "e": 7.1}, {"w": "be", "s": 7.1, "e": 7.3}, {"w": "a", "s": 7.3, "e": 7.44}, {"w": "fantastic", "s": 7.44, "e": 7.86}, {"w": "opportunity", "s": 7.86, "e": 8.96}, {"w": "for", "s": 8.96, "e": 9.32}, {"w": "Mika.", "s": 9.32, "e": 9.64}]}, {"start": 12.54, "end": 15.64, "text": "How are you? Fine, thank you.", "words": [{"w": "How", "s": 12.54, "e": 13.26}, {"w": "are", "s": 13.26, "e": 13.4}, {"w": "you?", "s": 13.4, "e": 13.62}, {"w": "Fine,", "s": 14.54, "e": 14.98}, {"w": "thank", "s": 15.1, "e": 15.26}, {"w": "you.", "s": 15.26, "e": 15.64}]}, {"start": 18.86, "end": 21.76, "text": "Anne does a noble job at the children's hospital.", "words": [{"w": "Anne", "s": 18.86, "e": 19.16}, {"w": "does", "s": 19.16, "e": 19.42}, {"w": "a", "s": 19.42, "e": 19.66}, {"w": "noble", "s": 19.66, "e": 19.9}, {"w": "job", "s": 19.9, "e": 20.36}, {"w": "at", "s": 20.36, "e": 20.62}, {"w": "the", "s": 20.62, "e": 20.74}, {"w": "children's", "s": 20.74, "e": 21.28}, {"w": "hospital.", "s": 21.28, "e": 21.76}]}, {"start": 25.12, "end": 27.5, "text": "Treasures can be lost in an accident.", "words": [{"w": "Treasures", "s": 25.12, "e": 25.76}, {"w": "can", "s": 25.76, "e": 26.08}, {"w": "be", "s": 26.08, "e": 26.28}, {"w": "lost", "s": 26.28, "e": 26.66}, {"w": "in", "s": 26.66, "e": 26.88}, {"w": "an", "s": 26.88, "e": 27.0}, {"w": "accident.", "s": 27.0, "e": 27.5}]}, {"start": 30.42, "end": 34.02, "text": "The road curves to the left about a mile from here.", "words": [{"w": "T