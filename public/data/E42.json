[{"start": 0.0, "end": 2.98, "text": "My father was too poor to go to college.", "words": [{"w": "My", "s": 0.0, "e": 0.64}, {"w": "father", "s": 0.64, "e": 0.96}, {"w": "was", "s": 0.96, "e": 1.3}, {"w": "too", "s": 1.3, "e": 1.56}, {"w": "poor", "s": 1.56, "e": 1.92}, {"w": "to", "s": 1.92, "e": 2.18}, {"w": "go", "s": 2.18, "e": 2.32}, {"w": "to", "s": 2.32, "e": 2.42}, {"w": "college.", "s": 2.42, "e": 2.98}]}, {"start": 5.86, "end": 8.1, "text": "The poor child was crying.", "words": [{"w": "The", "s": 5.86, "e": 6.58}, {"w": "poor", "s": 6.58, "e": 6.88}, {"w": "child", "s": 6.88, "e": 7.3}, {"w": "was", "s": 7.3, "e": 7.62}, {"w": "crying.", "s": 7.62, "e": 8.1}]}, {"start": 11.0, "end": 13.66, "text": "The police arrested him for theft.", "words": [{"w": "The", "s": 11.0, "e": 11.72}, {"w": "police", "s": 11.72, "e": 12.12}, {"w": "arrested", "s": 12.12, "e": 12.76}, {"w": "him", "s": 12.76, "e": 13.04}, {"w": "for", "s": 13.04, "e": 13.34}, {"w": "theft.", "s": 13.34, "e": 13.66}]}, {"start": 16.68, "end": 20.48, "text": "The man was found guilty but avoided going to prison.", "words": [{"w": "The", "s": 16.68, "e": 17.4}, {"w": "man", "s": 17.4, "e": 17.64}, {"w": "was", "s": 17.64, "e": 17.9}, {"w": "found", "s": 17.9, "e": 18.22}, {"w": "guilty", "s": 18.22, "e": 18.64}, {"w": "but", "s": 18.64, "e": 19.06}, {"w": "avoided", "s": 19.06, "e": 19.54}, {"w": "going", "s": 19.54, "e": 19.9}, {"w": "to", "s": 19.9, "e": 20.16}, {"w": "prison.", "s": 20.16, "e": 20.48}]}, {"start": 24.0, "end": 25.56, "text": "We allowed him to go out.", "words": [{"w": "We", "s": 23.8, "e": 24.16}, {"w": "allowed", "s": 24.16, "e": 24.48}, {"w": "him", "s": 24.48, "e": 24.8}, {"w": "to", "s": 24.8, "e": 24.98}, {"w": "go", "s": 24.98, "e": 25.16}, {"w": "out.", "s": 25.16, "e": 25.56}]}, {"start": 28.32, "end": 32.16, "text": "You are not allowed to take pictures in this theater.", "words": [{"w": "You", "s": 28.32, "e": 29.04}, {"w": "are", "s": 29.04, "e": 29.24}, {"w": "no