[{"start": 0.0, "end": 3.88, "text": "My son amazes me with his skill at playing the piano.", "words": [{"w": "My", "s": 0.0, "e": 0.7}, {"w": "son", "s": 0.7, "e": 1.06}, {"w": "amazes", "s": 1.06, "e": 1.66}, {"w": "me", "s": 1.66, "e": 1.94}, {"w": "with", "s": 1.94, "e": 2.18}, {"w": "his", "s": 2.18, "e": 2.38}, {"w": "skill", "s": 2.38, "e": 2.74}, {"w": "at", "s": 2.74, "e": 2.92}, {"w": "playing", "s": 2.92, "e": 3.24}, {"w": "the", "s": 3.24, "e": 3.5}, {"w": "piano.", "s": 3.5, "e": 3.88}]}, {"start": 6.82, "end": 9.64, "text": "Our cat gave birth to three kittens.", "words": [{"w": "Our", "s": 6.82, "e": 7.54}, {"w": "cat", "s": 7.54, "e": 7.78}, {"w": "gave", "s": 7.78, "e": 8.14}, {"w": "birth", "s": 8.14, "e": 8.48}, {"w": "to", "s": 8.48, "e": 8.84}, {"w": "three", "s": 8.84, "e": 9.16}, {"w": "kittens.", "s": 9.16, "e": 9.64}]}, {"start": 12.88, "end": 16.58, "text": "Usain Bolt holds the world record for the 100 meters.", "words": [{"w": "Usain", "s": 12.88, "e": 13.6}, {"w": "Bolt", "s": 13.6, "e": 13.86}, {"w": "holds", "s": 13.86, "e": 14.38}, {"w": "the", "s": 14.38, "e": 14.64}, {"w": "world", "s": 14.64, "e": 14.92}, {"w": "record", "s": 14.92, "e": 15.36}, {"w": "for", "s": 15.36, "e": 15.66}, {"w": "the", "s": 15.66, "e": 15.8}, {"w": "100", "s": 15.8, "e": 16.24}, {"w": "meters.", "s": 16.24, "e": 16.58}]}, {"start": 19.64, "end": 22.28, "text": "It is a matter of general knowledge.", "words": [{"w": "It", "s": 19.64, "e": 20.36}, {"w": "is", "s": 20.36, "e": 20.54}, {"w": "a", "s": 20.54, "e": 20.66}, {"w": "matter", "s": 20.66, "e": 20.92}, {"w": "of", "s": 20.92, "e": 21.24}, {"w": "general", "s": 21.24, "e": 21.6}, {"w": "knowledge.", "s": 21.6, "e": 22.28}]}, {"start": 25.3, "end": 28.32, "text": "Everyone should be respected as an individual.", "words": [{"w": "Everyone", "s": 25.3, "e": 26.02}, {"w": "should", "s": 26.02, "e": 26.52}, {"w": "be", "s": 26.52, "e": 26.72}, {"w": "respected", "s": 26.72, "e": 27.3}, {"w": "as", "s": 27.3, "e": 27.62}, {"w": "an", "s": 27.62, "e": 27.78}, {"w": "individual.", "s": 27.78, "e": 28.32}]}, {"start": 31.28, "end": 34.62, "text": "My eyesight began to get worse in my teens.", "words": [{"w": "My", "s": 31.28, "e": 32.0}, {"w": "eyesight", "s": 32.0, "e": 32.5}, {"w": "began", "s": 32.5, "e": 32.96}, {"w": "to", "s": 32.96, "e": 33.22}, {"w": "get", "s": 33.22, "e": 33.4}, {"w": "worse", "s": 33.4, "e": 33.78}, {"w": "in", "s": 33.78, "e": 33.98}, {"w": "my", "s": 33.98, "e": 34.18}, {"w": "teens.", "s": 34.18, "e": 34.62}]}, {"start": 37.94, "end": 40.88, "text": "I have problems with vision in my right eye.", "words": [{"w": "I", "s": 37.94, "e": 38.26}, {"w": "have", "s": 38.26, "e": 38.52}, {"w": "problems", "s": 38.52, "e": 39.02}, {"w": "with", "s": 39.02, "e": 39.38}, {"w": "vision", "s": 39.38, "e": 39.74}, {"w": "in", "s": 39.74, "e": 40.0}, {"w": "my", "s": 40.0, "e": 40.2}, {"w": "right", "s": 40.2, "e": 40.46}, {"w": "eye.", "s": 40.46, "e": 40.88}]}, {"start": 43.86, "end": 47.4, "text": "The blind man took his guide dog everywhere with him.", "words": [{"w": "The", "s": 43.86, "e": 44.4}, {"w": "blind", "s": 44.4, "e": 44.72}, {"w": "man", "s": 44.72, "e": 45.1}, {"w": "took", "s": 45.1, "e": 45.38}, {"w": "his", "s": 45.38, "e": 45.64}, {"w": "guide", "s": 45.64, "e": 45.9}, {"w": "dog", "s": 45.9, "e": 46.2}, {"w": "everywhere", "s": 46.2, "e": 46.62}, {"w": "with", "s": 46.62, "e": 47.14}, {"w": "him.", "s": 47.14, "e": 47.4}]}, {"start": 50.38, "end": 54.86, "text": "Beethoven didn't give up composing even after he became deaf.", "words": [{"w": "Beethoven", "s": 50.38, "e": 51.22}, {"w": "didn't", "s": 51.22, "e": 51.92}, {"w": "give", "s": 51.92, "e": 52.1}, {"w": "up", "s": 52.1, "e": 52.28}, {"w": "composing", "s": 52.28, "e": 52.96}, {"w": "even", "s": 52.96, "e": 53.42}, {"w": "after", "s": 53.42, "e": 53.84}, {"w": "he", "s": 53.84, "e": 54.08}, {"w": "became", "s": 54.08, "e": 54.48}, {"w": "deaf.", "s": 54.48, "e": 54.86}]}]