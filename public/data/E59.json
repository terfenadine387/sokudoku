[{"start": 0.0, "end": 3.76, "text": "The magician gave a marvelous performance for the children.", "words": [{"w": "The", "s": 0.0, "e": 0.64}, {"w": "magician", "s": 0.64, "e": 1.04}, {"w": "gave", "s": 1.04, "e": 1.44}, {"w": "a", "s": 1.44, "e": 1.62}, {"w": "marvelous", "s": 1.62, "e": 2.08}, {"w": "performance", "s": 2.08, "e": 2.74}, {"w": "for", "s": 2.74, "e": 3.18}, {"w": "the", "s": 3.18, "e": 3.32}, {"w": "children.", "s": 3.32, "e": 3.76}]}, {"start": 6.6, "end": 10.8, "text": "The object of this study is women in their 20s.", "words": [{"w": "The", "s": 6.6, "e": 7.44}, {"w": "object", "s": 7.44, "e": 7.9}, {"w": "of", "s": 7.9, "e": 8.18}, {"w": "this", "s": 8.18, "e": 8.4}, {"w": "study", "s": 8.4, "e": 8.76}, {"w": "is", "s": 8.76, "e": 9.16}, {"w": "women", "s": 9.16, "e": 9.52}, {"w": "in", "s": 9.52, "e": 9.86}, {"w": "their", "s": 9.86, "e": 10.02}, {"w": "20s.", "s": 10.02, "e": 10.8}]}, {"start": 14.0, "end": 15.98, "text": "They objected to our plans.", "words": [{"w": "They", "s": 13.78, "e": 14.2}, {"w": "objected", "s": 14.2, "e": 14.98}, {"w": "to", "s": 14.98, "e": 15.22}, {"w": "our", "s": 15.22, "e": 15.4}, {"w": "plans.", "s": 15.4, "e": 15.98}]}, {"start": 18.76, "end": 21.7, "text": "We have hit our sales target already.", "words": [{"w": "We", "s": 18.76, "e": 19.6}, {"w": "have", "s": 19.6, "e": 19.92}, {"w": "hit", "s": 19.92, "e": 20.18}, {"w": "our", "s": 20.18, "e": 20.42}, {"w": "sales", "s": 20.42, "e": 20.8}, {"w": "target", "s": 20.8, "e": 21.28}, {"w": "already.", "s": 21.28, "e": 21.7}]}, {"start": 24.4, "end": 27.44, "text": "I can't resist another piece of cake.", "words": [{"w": "I", "s": 24.4, "e": 25.32}, {"w": "can't", "s": 25.32, "e": 25.7}, {"w": "resist", "s": 25.7, "e": 26.04}, {"w": "another", "s": 26.04, "e": 26.54}, {"w": "piece", "s": 26.54, "e": 26.94}, {"w": "of", "s": 26.94, "e": 27.12}, {"w": "cake.", "s": 27.12, "e": 27.44}]}, {"start": 30.1, "end": 34.0, "text": "We should protest against these unfair