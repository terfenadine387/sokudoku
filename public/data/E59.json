{"w": "his", "s": 117.24, "e": 117.52}, {"w": "real", "s": 117.52, "e": 117.82}, {"w": "name.", "s": 117.82, "e": 118.16}]}, {"start": 120.82, "end": 124.82, "text": "On Sundays, I walk around and enjoy nature.", "words": [{"w": "On", "s": 120.82, "e": 121.7}, {"w": "Sundays,", "s": 121.7, "e": 122.14}, {"w": "I", "s": 122.58, "e": 122.84}, {"w": "walk", "s": 122.84, "e": 123.12}, {"w": "around", "s": 123.12, "e": 123.58}, {"w": "and", "s": 123.58, "e": 123.98}, {"w": "enjoy", "s": 123.98, "e": 124.38}, {"w": "nature.", "s": 124.38, "e": 124.82}]}, {"start": 127.58, "end": 130.18, "text": "They gathered shells on the beach.", "words": [{"w": "They", "s": 127.58, "e": 128.46}, {"w": "gathered", "s": 128.46, "e": 128.82}, {"w": "shells", "s": 128.82, "e": 129.32}, {"w": "on", "s": 129.32, "e": 129.64}, {"w": "the", "s": 129.64, "e": 129.8}, {"w": "beach.", "s": 129.8, "e": 130.18}]}]