 87.48}, {"w": "to", "s": 87.48, "e": 87.76}, {"w": "fight", "s": 87.76, "e": 88.04}, {"w": "back.", "s": 88.04, "e": 88.4}]}, {"start": 91.34, "end": 94.72, "text": "Large crowds gathered outside the city hall.", "words": [{"w": "Large", "s": 91.34, "e": 92.1}, {"w": "crowds", "s": 92.1, "e": 92.74}, {"w": "gathered", "s": 92.74, "e": 93.12}, {"w": "outside", "s": 93.12, "e": 93.76}, {"w": "the", "s": 93.76, "e": 94.08}, {"w": "city", "s": 94.08, "e": 94.3}, {"w": "hall.", "s": 94.3, "e": 94.72}]}, {"start": 97.6, "end": 101.86, "text": "This company employs a limited number of staff at night.", "words": [{"w": "This", "s": 97.6, "e": 98.36}, {"w": "company", "s": 98.36, "e": 98.86}, {"w": "employs", "s": 98.86, "e": 99.42}, {"w": "a", "s": 99.42, "e": 99.68}, {"w": "limited", "s": 99.68, "e": 100.0}, {"w": "number", "s": 100.0, "e": 100.52}, {"w": "of", "s": 100.52, "e": 100.78}, {"w": "staff", "s": 100.78, "e": 101.18}, {"w": "at", "s": 101.18, "e": 101.5}, {"w": "night.", "s": 101.5, "e": 101.86}]}, {"start": 104.72, "end": 107.04, "text": "He has lost his mobile phone.", "words": [{"w": "He", "s": 104.72, "e": 105.36}, {"w": "has", "s": 105.36, "e": 105.64}, {"w": "lost", "s": 105.64, "e": 106.04}, {"w": "his", "s": 106.04, "e": 106.26}, {"w": "mobile", "s": 106.26, "e": 106.54}, {"w": "phone.", "s": 106.54, "e": 107.04}]}, {"start": 110.08, "end": 113.92, "text": "Looking at your phone while walking is a silly thing to do.", "words": [{"w": "Looking", "s": 110.08, "e": 110.68}, {"w": "at", "s": 110.68, "e": 110.96}, {"w": "your", "s": 110.96, "e": 111.12}, {"w": "phone", "s": 111.12, "e": 111.5}, {"w": "while", "s": 111.5, "e": 111.8}, {"w": "walking", "s": 111.8, "e": 112.24}, {"w": "is", "s": 112.24, "e": 112.58}, {"w": "a", "s": 112.58, "e": 112.72}, {"w": "silly", "s": 112.72, "e": 113.04}, {"w": "thing", "s": 113.04, "e": 113.42}, {"w": "to", "s": 113.42, "e": 113.64}, {"w": "do.", "s": 113.64, "e": 113.92}]}, {"start": 116.7, "end": 119.48, "text": "You mustn't worry about appearing foolish.", "words": [{"w": "You", "s": 116.7, "e": 117.46}, {"w": "mustn't", "s": 117.46, "e": 117.82}, {"w": "worry", "s": 117.82, "e": 118.18}, {"w": "about", "s": 118.18, "e": 118.56}, {"w": "appearing", "s": 118.56, "e": 118.96}, {"w": "foolish.", "s": 118.96, "e": 119.48}]}, {"start": 122.48, "end": 125.64, "text": "A fool and his money are soon parted.", "words": [{"w": "A", "s": 122.48, "e": 123.24}, {"w": "fool", "s": 123.24, "e": 123.54}, {"w": "and", "s": 123.54, "e": 123.84}, {"w": "his", "s": 123.84, "e": 124.02}, {"w": "money", "s": 124.02, "e": 124.3}, {"w": "are", "s": 124.3, "e": 124.62}, {"w": "soon", "s": 124.62, "e": 125.02}, {"w": "parted.", "s": 125.02, "e": 125.64}]}, {"start": 128.32, "end": 131.9, "text": "I'd like to apologize for my stupid actions.", "words": [{"w": "I'd", "s": 128.32, "e": 129.08}, {"w": "like", "s": 129.08, "e": 129.26}, {"w": "to", "s": 129.26, "e": 129.48}, {"w": "apologize", "s": 129.48, "e": 130.18}, {"w": "for", "s": 130.18, "e": 130.6}, {"w": "my", "s": 130.6, "e": 130.82}, {"w": "stupid", "s": 130.82, "e": 131.26}, {"w": "actions.", "s": 131.26, "e": 131.9}]}, {"start": 134.92, "end": 138.28, "text": "I'm sorry if you think my idea is ridiculous.", "words": [{"w": "I'm", "s": 134.92, "e": 135.68}, {"w": "sorry", "s": 135.68, "e": 136.08}, {"w": "if", "s": 136.08, "e": 136.34}, {"w": "you", "s": 136.34, "e": 136.48}, {"w": "think", "s": 136.48, "e": 136.74}, {"w": "my", "s": 136.74, "e": 137.0}, {"w": "idea", "s": 137.0, "e": 137.44}, {"w": "is", "s": 137.44, "e": 137.8}, {"w": "ridiculous.", "s": 137.8, "e": 138.28}]}, {"start": 141.4, "end": 143.32, "text": "Tell me what's on your mind.", "words": [{"w": "Tell", "s": 141.4, "e": 142.16}, {"w": "me", "s": 142.16, "e": 142.34}, {"w": "what's", "s": 142.34, "e": 142.6}, {"w": "on", "s": 142.6, "e": 142.76}, {"w": "your", "s": 142.76, "e": 142.94}, {"w": "mind.", "s": 142.94, "e": 143.32}]}, {"start": 146.08, "end": 148.32, "text": "Do yo