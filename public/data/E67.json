[{"start": 0.0, "end": 3.9, "text": "I read the report and subsequently passed it to my boss.", "words": [{"w": "I", "s": 0.0, "e": 0.6}, {"w": "read", "s": 0.6, "e": 0.82}, {"w": "the", "s": 0.82, "e": 0.96}, {"w": "report", "s": 0.96, "e": 1.4}, {"w": "and", "s": 1.4, "e": 1.78}, {"w": "subsequently", "s": 1.78, "e": 2.34}, {"w": "passed", "s": 2.34, "e": 3.02}, {"w": "it", "s": 3.02, "e": 3.2}, {"w": "to", "s": 3.2, "e": 3.38}, {"w": "my", "s": 3.38, "e": 3.56}, {"w": "boss.", "s": 3.56, "e": 3.9}]}, {"start": 6.94, "end": 9.3, "text": "I take a walk nearly every day.", "words": [{"w": "I", "s": 6.94, "e": 7.52}, {"w": "take", "s": 7.52, "e": 7.74}, {"w": "a", "s": 7.74, "e": 7.88}, {"w": "walk", "s": 7.88, "e": 8.14}, {"w": "nearly", "s": 8.14, "e": 8.44}, {"w": "every", "s": 8.44, "e": 8.94}, {"w": "day.", "s": 8.94, "e": 9.3}]}, {"start": 12.18, "end": 14.26, "text": "The dove is a symbol of peace.", "words": [{"w": "The", "s": 12.18, "e": 12.76}, {"w": "dove", "s": 12.76, "e": 13.02}, {"w": "is", "s": 13.02, "e": 13.28}, {"w": "a", "s": 13.28, "e": 13.48}, {"w": "symbol", "s": 13.48, "e": 13.72}, {"w": "of", "s": 13.72, "e": 13.98}, {"w": "peace.", "s": 13.98, "e": 14.26}]}, {"start": 17.44, "end": 20.38, "text": "This is the perfect setting for a romantic walk.", "words": [{"w": "This", "s": 17.44, "e": 18.02}, {"w": "is", "s": 18.02, "e": 18.2}, {"w": "the", "s": 18.2, "e": 18.32}, {"w": "perfect", "s": 18.32, "e": 18.6}, {"w": "setting", "s": 18.6, "e": 19.1}, {"w": "for", "s": 19.1, "e": 19.36}, {"w": "a", "s": 19.36, "e": 19.5}, {"w": "romantic", "s": 19.5, "e": 19.86}, {"w": "walk.", "s": 19.86, "e": 20.38}]}, {"start": 23.24, "end": 26.48, "text": "I represented my school in the speech contest.", "words": [{"w": "I", "s": 23.24, "e": 23.92}, {"w": "represented", "s": 23.92, "e": 24.42}, {"w": "my", "s": 24.42, "e": 24.8}, {"w": "school", "s": 24.8, "e": 25.2}, {"w": "in", "s": 25.2, "e": 25.46}, {"w": "the", "s": 25.46, "e": 25.6}, {"w": "speech", "s":