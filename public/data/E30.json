[{"start": 0.0, "end": 2.94, "text": "I have never experienced such hot weather.", "words": [{"w": "I", "s": 0.0, "e": 0.62}, {"w": "have", "s": 0.62, "e": 0.76}, {"w": "never", "s": 0.76, "e": 1.02}, {"w": "experienced", "s": 1.02, "e": 1.84}, {"w": "such", "s": 1.84, "e": 2.24}, {"w": "hot", "s": 2.24, "e": 2.6}, {"w": "weather.", "s": 2.6, "e": 2.94}]}, {"start": 5.86, "end": 8.56, "text": "My mother suffers from bad headaches.", "words": [{"w": "My", "s": 5.86, "e": 6.56}, {"w": "mother", "s": 6.56, "e": 6.8}, {"w": "suffers", "s": 6.8, "e": 7.24}, {"w": "from", "s": 7.24, "e": 7.72}, {"w": "bad", "s": 7.72, "e": 8.14}, {"w": "headaches.", "s": 8.14, "e": 8.56}]}, {"start": 11.76, "end": 15.64, "text": "That is an area of science that I am not familiar with.", "words": [{"w": "That", "s": 11.76, "e": 12.4}, {"w": "is", "s": 12.4, "e": 12.68}, {"w": "an", "s": 12.68, "e": 12.82}, {"w": "area", "s": 12.82, "e": 13.08}, {"w": "of", "s": 13.08, "e": 13.38}, {"w": "science", "s": 13.38, "e": 13.84}, {"w": "that", "s": 13.84, "e": 14.14}, {"w": "I", "s": 14.14, "e": 14.28}, {"w": "am", "s": 14.28, "e": 14.38}, {"w": "not", "s": 14.38, "e": 14.62}, {"w": "familiar", "s": 14.62, "e": 15.02}, {"w": "with.", "s": 15.02, "e": 15.64}]}, {"start": 19.0, "end": 20.7, "text": "He is in a poor state of health.", "words": [{"w": "He", "s": 18.75, "e": 19.1}, {"w": "is", "s": 19.1, "e": 19.26}, {"w": "in", "s": 19.26, "e": 19.38}, {"w": "a", "s": 19.38, "e": 19.46}, {"w": "poor", "s": 19.46, "e": 19.76}, {"w": "state", "s": 19.76, "e": 20.08}, {"w": "of", "s": 20.08, "e": 20.3}, {"w": "health.", "s": 20.3, "e": 20.7}]}, {"start": 23.5, "end": 26.62, "text": "I disagree with some of the points in your statement.", "words": [{"w": "I", "s": 23.5, "e": 24.2}, {"w": "disagree", "s": 24.2, "e": 24.48}, {"w": "with", "s": 24.48, "e": 24.86}, {"w": "some", "s": 24.86, "e": 25.16}, {"w": "of", "s": 25.16, "e": 25.3}, {"w": "the", "s": 25.3, "e": 25.4}, {"w": "points", "s": 25.4, "e": 25.78}, {"w": "in", "s": 25.78, "e": 26.06}, {"w": "your", "s": 26.06, "e": 26.18}, {"w": "statement.", "s": 26.18, "e": 26.62}]}, {"start": 30.0, "end": 32.82, "text": "Jim declared he was tired and went to bed.", "words": [{"w": "Jim", "s": 30.0, "e": 30.44}, {"w": "declared", "s": 30.44, "e": 30.88}, {"w": "he", "s": 30.88, "e": 31.14}, {"w": "was", "s": 31.14, "e": 31.34}, {"w": "tired", "s": 31.34, "e": 31.76}, {"w": "and", "s": 31.76, "e": 32.1}, {"w": "went", "s": 32.1, "e": 32.34}, {"w": "to", "s": 32.34, "e": 32.54}, {"w": "bed.", "s": 32.54, "e": 32.82}]}, {"start": 35.64, "end": 37.78, "text": "He is in serious condition.", "words": [{"w": "He", "s": 35.64, "e": 36.36}, {"w": "is", "s": 36.36, "e": 36.52}, {"w": "in", "s": 36.52, "e": 36.68}, {"w": "serious", "s": 36.68, "e": 37.08}, {"w": "condition.", "s": 37.08, "e": 37.78}]}, {"start": 40.64, "end": 43.92, "text": "They rose up to improve their working conditions.", "words": [{"w": "They", "s": 40.64, "e": 41.36}, {"w": "rose", "s": 41.36, "e": 41.62}, {"w": "up", "s": 41.62, "e": 41.92}, {"w": "to", "s": 41.92, "e": 42.08}, {"w": "improve", "s": 42.08, "e": 42.58}, {"w": "their", "s": 42.58, "e": 42.94}, {"w": "working", "s": 42.94, "e": 43.28}, {"w": "conditions.", "s": 43.28, "e": 43.92}]}, {"start": 47.36, "end": 49.86, "text": "The economic situation is not good.", "words": [{"w": "The", "s": 47.36, "e": 47.66}, {"w": "economic", "s": 47.66, "e": 48.04}, {"w": "situation", "s": 48.04, "e": 48.62}, {"w": "is", "s": 48.62, "e": 49.18}, {"w": "not", "s": 49.18, "e": 49.5}, {"w": "good.", "s": 49.5, "e": 49.86}]}, {"start": 52.84, "end": 55.92, "text": "That country is now in a difficult position.", "words": [{"w": "That", "s": 52.84, "e": 53.56}, {"w": "country", "s": 53.56, "e": 54.0}, {"w": "is", "s": 54.0, "e": 54.32}, {"w": "now", "s": 54.32, "e": 54.58}, {"w": "in", "s": 54.58, "e": 54.74}, {"w": "a", "s": 54.74, "e": 54.88}, {"w": "difficult", "s": 54.88, "e": 55.22}, {"w": "position.", "s": 55.22, "e": 55.92}]}, {"start": 59.0, "end": 62.08, "text": "The fact is that we don't want to go there with you.", "words": [{"w": "The", "s": 59.0, "e": 59.56}, {"w": "fact", "s": 59.56, "e": 59.86}, {"w": "is", "s": 59.86, "e": 60.14}, {"w": "that", "s": 60.14, "e": 60.32}, {"w": "we", "s": 60.32, "e": 60.44}, {"w": "don't", "s": 60.44, "e": 60.64}, {"w": "want", "s": 60.64, "e": 60.9}, {"w": "to", "s": 60.9, "e": 61.12}, {"w": "go", "s": 61.12, "e": 61.3}, {"w": "there", "s": 61.3, "e": 61.54}, {"w": "with", "s": 61.54, "e": 61.82}, {"w": "you.", "s": 61.82, "e": 62.08}]}, {"start": 65.16, "end": 68.46, "text": "One problem with the plan is that we don't have enough time.", "words": [{"w": "One", "s": 65.16, "e": 65.72}, {"w": "problem", "s": 65.72, "e": 66.14}, {"w": "with", "s": 66.14, "e": 66.34}, {"w": "the", "s": 66.34, "e": 66.46}, {"w": "plan", "s": 66.46, "e": 66.76}, {"w": "is", "s": 66.76, "e": 66.94}, {"w": "that", "s": 66.94, "e": 67.08}, {"w": "we", "s": 67.08, "e": 67.2}, {"w": "don't", "s": 67.2, "e": 67.48}, {"w": "have", "s": 67.48, "e": 67.78}, {"w": "enough", "s": 67.78, "e": 67.98}, {"w": "time.", "s": 67.98, "e": 68.46}]}, {"start": 71.44, "end": 74.02, "text": "He is having trouble with his eldest son.", "words": [{"w": "He", "s": 71.44, "e": 72.0}, {"w": "is", "s": 72.0, "e": 72.12}, {"w": "having", "s": 72.12, "e": 72.32}, {"w": "trouble", "s": 72.32, "e": 72.7}, {"w": "with", "s": 72.7, "e": 73.02}, {"w": "his", "s": 73.02, "e": 73.2}, {"w": "eldest", "s": 73.2, "e": 73.48}, {"w": "son.", "s": 73.48, "e": 74.02}]}, {"start": 77.12, "end": 80.04, "text": "Although he is very rich, he is not happy.", "words": [{"w": "Although", "s": 77.12, "e": 77.68}, {"w": "he", "s": 77.68, "e": 77.92}, {"w": "is", "s": 77.92, "e": 78.08}, {"w": "very", "s": 78.08, "e": 78.36}, {"w": "rich,", "s": 78.36, "e": 78.8}, {"w": "he", "s": 79.1, "e": 79.2}, {"w": "is", "s": 79.2, "e": 79.36}, {"w": "not", "s": 79.36, "e": 79.62}, {"w": "happy.", "s": 79.62, "e": 80.04}]}, {"start": 83.02, "end": 85.0, "text": "He tried to cross the ocean.", "words": [{"w": "He", "s": 83.02, "e": 83.58}, {"w": "tried", "s": 83.58, "e": 83.82}, {"w": "to", "s": 83.82, "e": 84.06}, {"w": "cross", "s": 84.06, "e": 84.36}, {"w": "the", "s": 84.36, "e": 84.64}, {"w": "ocean.", "s": 84.64, "e": 85.0}]}, {"start": 87.9, "end": 89.6, "text": "This tastes sweet.", "words": [{"w": "This", "s": 87.9, "e": 88.66}, {"w": "tastes", "s": 88.66, "e": 89.02}, {"w": "sweet.", "s": 89.02, "e": 89.6}]}, {"start": 92.42, "end": 94.88, "text": "There is no accounting for taste.", "words": [{"w": "There", "s": 92.42, "e": 93.18}, {"w": "is", "s": 93.18, "e": 93.34}, {"w": "no", "s": 93.34, "e": 93.54}, {"w": "accounting", "s": 93.54, "e": 94.06}, {"w": "for", "s": 94.06, "e": 94.42}, {"w": "taste.", "s": 94.42, "e": 94.88}]}, {"start": 97.68, "end": 100.32, "text": "A small boat floated on the lake.", "words": [{"w": "A", "s": 97.68, "e": 98.44}, {"w": "small", "s": 98.44, "e": 98.76}, {"w": "boat", "s": 98.76, "e": 99.16}, {"w": "floated", "s": 99.16, "e": 99.62}, {"w": "on", "s": 99.62, "e": 99.88}, {"w": "the", "s": 99.88, "e": 100.02}, {"w": "lake.", "s": 100.02, "e": 100.32}]}, {"start": 103.04, "end": 105.56, "text": "I stood all the way on the train.", "words": [{"w": "I", "s": 103.04, "e": 103.8}, {"w": "stood", "s": 103.8, "e": 104.08}, {"w": "all", "s": 104.08, "e": 104.48}, {"w": "the", "s": 104.48, "e": 104.66}, {"w": "way", "s": 104.66, "e": 104.9}, {"w": "on", "s": 104.9, "e": 105.1}, {"w": "the", "s": 105.1, "e": 105.22}, {"w": "train.", "s": 105.22, "e": 105.56}]}, {"start": 108.34, "end": 110.62, "text": "Our school stands on a hill.", "words": [{"w": "Our", "s": 108.34, "e": 109.1}, {"w": "school", "s": 109.1, "e": 109.44}, {"w": "stands", "s": 109.44, "e": 109.8}, {"w": "on", "s": 109.8, "e": 110.2}, {"w": "a", "s": 110.2, "e": 110.36}, {"w": "hill.", "s": 110.36, "e": 110.62}]}, {"start": 113.4, "end": 115.66, "text": "I can't stand this cold.", 