 {"w": "of", "s": 26.88, "e": 27.18}, {"w": "his", "s": 27.18, "e": 27.36}, {"w": "family.", "s": 27.36, "e": 27.76}]}, {"start": 30.58, "end": 32.8, "text": "He described what had happened.", "words": [{"w": "He", "s": 30.58, "e": 31.3}, {"w": "described", "s": 31.3, "e": 31.7}, {"w": "what", "s": 31.7, "e": 32.14}, {"w": "had", "s": 32.14, "e": 32.36}, {"w": "happened.", "s": 32.36, "e": 32.8}]}, {"start": 35.6, "end": 37.74, "text": "His story is pure fiction.", "words": [{"w": "His", "s": 35.6, "e": 36.32}, {"w": "story", "s": 36.32, "e": 36.68}, {"w": "is", "s": 36.68, "e": 36.98}, {"w": "pure", "s": 36.98, "e": 37.28}, {"w": "fiction.", "s": 37.28, "e": 37.74}]}, {"start": 40.66, "end": 44.48, "text": "My mother kept all my drawings from when I was in kindergarten.", "words": [{"w": "My", "s": 40.66, "e": 41.38}, {"w": "mother", "s": 41.38, "e": 41.64}, {"w": "kept", "s": 41.64, "e": 42.02}, {"w": "all", "s": 42.02, "e": 42.24}, {"w": "my", "s": 42.24, "e": 42.42}, {"w": "drawings", "s": 42.42, "e": 42.88}, {"w": "from", "s": 42.88, "e": 43.26}, {"w": "when", "s": 43.26, "e": 43.48}, {"w": "I", "s": 43.48, "e": 43.66}, {"w": "was", "s": 43.66, "e": 43.86}, {"w": "in", "s": 43.86, "e": 44.02}, {"w": "kindergarten.", "s": 44.02, "e": 44.48}]}, {"start": 48.12, "end": 51.56, "text": "Mika is learning to paint at an art college in the city.", "words": [{"w": "Mika", "s": 48.12, "e": 48.62}, {"w": "is", "s": 48.62, "e": 48.92}, {"w": "learning", "s": 48.92, "e": 49.16}, {"w": "to", "s": 49.16, "e": 49.4}, {"w": "paint", "s": 49.4, "e": 49.72}, {"w": "at", "s": 49.72, "e": 49.96}, {"w": "an", "s": 49.96, "e": 50.12}, {"w": "art", "s": 50.12, "e": 50.34}, {"w": "college", "s": 50.34, "e": 50.74}, {"w": "in", "s": 50.74, "e": 51.12}, {"w": "the", "s": 51.12, "e": 51.28}, {"w": "city.", "s": 51.28, "e": 51.56}]}, {"start": 54.4, "end": 56.7, "text": "He added sugar to his coffee.", "words": [{"w": "He", "s": 54.4, "e": 55.12}, {"w": "added", "s": 55.12, "e": 55.34}, {"